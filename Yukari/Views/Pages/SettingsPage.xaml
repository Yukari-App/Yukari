<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Yukari.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Yukari.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:enums="using:Yukari.Enums"
      xmlns:helpers="using:Yukari.Helpers.UI"
      xmlns:local="using:Yukari.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="using:Yukari.Models"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:vmc="using:Yukari.ViewModels.Components"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <converters:UrlToImageConverter x:Key="UrlToImageConverter" />

        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <Style x:Key="SettingsSectionHeaderTextBlockStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>

    </Page.Resources>

    <Grid RowDefinitions="Auto, *">
        <StackPanel Grid.Column="0"
                    MaxWidth="1000"
                    Padding="20,14,36,16"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
            <FontIcon FontSize="24" Glyph="&#xE713;" />
            <TextBlock x:Uid="SettingsHeader" VerticalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="0,0,16,16">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch" Spacing="{StaticResource SettingsCardSpacing}">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition FromVerticalOffset="50" />
                        <RepositionThemeTransition IsStaggeringEnabled="False" />
                    </StackPanel.ChildrenTransitions>

                    <!--  Appearance Section  -->
                    <TextBlock Margin="1,0,0,6" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Run x:Uid="AppearanceSection" FontWeight="Bold" />
                    </TextBlock>
                    <toolkit:SettingsCard x:Uid="AppThemeCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=}">
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableThemeModes}" SelectedItem="{x:Bind ViewModel.SelectedThemeMode, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <!--  Preferences Section  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Run x:Uid="PreferencesSection" FontWeight="Bold" />
                    </TextBlock>
                    <toolkit:SettingsCard x:Uid="AutoComicUpdateCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE895;}"
                                          IsEnabled="False">
                        <ToggleSwitch />
                    </toolkit:SettingsCard>

                    <!--  Reader Section  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Run x:Uid="ReaderSection" FontWeight="Bold" />
                    </TextBlock>
                    <toolkit:SettingsCard x:Uid="AutoFullscreenCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE740;}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsAutoFullscreen, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="ReadingModeCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE736;}">
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableReadingModes}" SelectedItem="{x:Bind ViewModel.SelectedReadingMode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="enums:ReadingMode">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon VerticalAlignment="Center" FontSize="14" Glyph="{x:Bind helpers:ReadingModeHelper.ToGlyph((enums:ReadingMode))}" />
                                        <TextBlock VerticalAlignment="Center" Text="{x:Bind helpers:ReadingModeHelper.ToDisplayName((enums:ReadingMode))}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="ScalingModeCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE9A6;}">
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableScalingModes}" SelectedItem="{x:Bind ViewModel.SelectedScalingMode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="enums:ScalingMode">
                                    <TextBlock Text="{x:Bind helpers:ScalingModeHelper.ToDisplayName((enums:ScalingMode))}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </toolkit:SettingsCard>

                    <!--  Sources Section  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Run x:Uid="SourcesSection" FontWeight="Bold" />
                    </TextBlock>
                    <toolkit:SettingsExpander x:Uid="ComicSourcesExpander"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              HeaderIcon="{ui:FontIcon Glyph=&#xE753;}"
                                              ItemsSource="{x:Bind ViewModel.ComicSourceItems, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Stretch" Orientation="Horizontal" Spacing="8">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Text="{x:Bind ViewModel.CoreVersion}" />
                            <Button x:Uid="NewComicSourceBT" Command="{x:Bind ViewModel.AddComicSourceCommand, Mode=OneWay}" />
                        </StackPanel>
                        <toolkit:SettingsExpander.ItemsHeader>
                            <InfoBar x:Uid="EmptyComicSourcesInfoBar"
                                     BorderThickness="0"
                                     CornerRadius="0"
                                     IsClosable="False"
                                     IsOpen="True"
                                     Severity="Informational"
                                     Visibility="{x:Bind ViewModel.IsComicSourcesEmpty, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        </toolkit:SettingsExpander.ItemsHeader>
                        <toolkit:SettingsExpander.ItemTemplate>
                            <DataTemplate x:DataType="vmc:ComicSourceItemViewModel">
                                <toolkit:SettingsCard Description="{x:Bind ComicSource.Description}" Header="{x:Bind ComicSource.Name}">
                                    <toolkit:SettingsCard.HeaderIcon>
                                        <ImageIcon Source="{x:Bind ComicSource.LogoUrl, Converter={StaticResource UrlToImageConverter}}" />
                                    </toolkit:SettingsCard.HeaderIcon>
                                    <StackPanel HorizontalAlignment="Stretch" Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Text="{x:Bind ComicSource.Version}" />
                                        <Border Height="20"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Visibility="{x:Bind IsOutdated, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock x:Uid="OutdatedBadge"
                                                       Margin="4,0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12" />
                                        </Border>
                                        <ToggleSwitch IsOn="{x:Bind IsEnabled, Mode=TwoWay}" />
                                        <Button Width="35"
                                                Height="35"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Content="{ui:FontIcon Glyph=&#xE712;}">
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem x:Uid="CheckForUpdatesMNItem" Command="{x:Bind OpenReleasesPageCommand}" Icon="Sync" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem x:Uid="DeleteComicSourceMNItem"
                                                                    Command="{x:Bind DeleteCommand}"
                                                                    CommandParameter="{x:Bind}"
                                                                    Icon="Delete" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </toolkit:SettingsCard>
                            </DataTemplate>
                        </toolkit:SettingsExpander.ItemTemplate>
                    </toolkit:SettingsExpander>

                    <toolkit:SettingsCard x:Uid="DefaultComicSourceCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE930;}"
                                          IsEnabled="{x:Bind ViewModel.IsAnyComicSourceEnabled, Mode=OneWay}">
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableComicSources, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.DefaultComicSource, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:ComicSourceModel">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ImageIcon Width="22"
                                                   Height="22"
                                                   VerticalAlignment="Center"
                                                   Source="{x:Bind LogoUrl, Converter={StaticResource UrlToImageConverter}}" />
                                        <TextBlock VerticalAlignment="Center" Text="{x:Bind Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </toolkit:SettingsCard>

                    <!--  Storage Section  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Run x:Uid="StorageSection" FontWeight="Bold" />
                    </TextBlock>
                    <toolkit:SettingsCard x:Uid="CleanUpCard" HeaderIcon="{ui:FontIcon Glyph=&#xE74D;}">
                        <Button x:Uid="CleanUpBT" Command="{x:Bind ViewModel.CleanUpStorageCommand}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </toolkit:SettingsCard>

                    <!--  About Section  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Run x:Uid="AboutSection" FontWeight="Bold" />
                    </TextBlock>
                    <toolkit:SettingsExpander x:Name="AboutExpander"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              Header="Yukari"
                                              HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/Square44x44Logo.altform-lightunplated_targetsize-32.png}">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsTextSelectionEnabled="True">
                            <Run x:Uid="VersionRun" />
                            <Run Text="{x:Bind ViewModel.YukariVersion, Mode=OneTime}" />
                        </TextBlock>
                        <toolkit:SettingsExpander.Items>
                            <!--  Project links  -->
                            <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                    <HyperlinkButton x:Uid="ProjectRepoHLBT" NavigateUri="https://github.com/Yukari-App/Yukari" />
                                    <HyperlinkButton x:Name="LicenseHLBT" NavigateUri="https://github.com/Yukari-App/Yukari/blob/master/LICENSE.txt" />
                                    <HyperlinkButton x:Uid="CheckUpdatesHLBT" NavigateUri="https://github.com/Yukari-App/Yukari/releases" />
                                </StackPanel>
                            </toolkit:SettingsCard>

                            <!--  Feedback links  -->
                            <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                    <HyperlinkButton x:Uid="FeedbackHLBT" NavigateUri="https://github.com/Yukari-App/Yukari/issues" />
                                </StackPanel>
                            </toolkit:SettingsCard>

                            <!--  Developer links  -->
                            <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                    <HyperlinkButton Content="TXG0Fk3 GitHub" NavigateUri="https://github.com/TXG0Fk3" />
                                </StackPanel>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
