<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Yukari.Views.Pages.ReaderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Yukari.Views.Controls"
      xmlns:converters="using:Yukari.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Yukari.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:vmc="using:Yukari.ViewModels.Components"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <converters:FullScreenToColumnWidthConverter x:Key="FullScreenToColumnWidthConverter" />
        <converters:ReadingModeToFlowDirectionConverter x:Key="ReadingModeToFlowDirectionConverter" />
        <converters:ReadingModeToOrientationConverter x:Key="ReadingModeToOrientationConverter" />
        <converters:UrlToImageConverter x:Key="UrlToImageConverter" />

        <Style x:Key="TitleBarButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="PageNavigationButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Page.Resources>


    <Grid RowDefinitions="Auto, *">
        <Grid.Resources>
            <Color x:Key="ButtonBackgroundDisabled">Transparent</Color>
            <Color x:Key="ButtonBorderBrushDisabled">Transparent</Color>
        </Grid.Resources>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="48"
              Margin="4,0,0,0"
              Padding="0"
              VerticalAlignment="Top"
              AutomationProperties.AutomationId="AppTitleBar"
              Background="Transparent"
              Visibility="{x:Bind ViewModel.IsFullscreen, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{x:Bind ViewModel.IsFullscreen, Converter={StaticResource FullScreenToColumnWidthConverter}, Mode=OneWay}" />
            </Grid.ColumnDefinitions>

            <Button x:Uid="BackToNavigationBT"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Content="{ui:FontIcon Glyph=&#xE72B;,
                                          FontSize=11}"
                    Style="{StaticResource TitleBarButtonStyle}" />
            <FontIcon Grid.Column="1"
                      Margin="4,0,0,0"
                      VerticalAlignment="Center"
                      FontSize="20"
                      Glyph="&#xE736;" />
            <Grid Grid.Column="2" ColumnDefinitions="*, Auto">
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Text="{x:Bind ViewModel.ComicTitle}"
                           TextWrapping="NoWrap"
                           ToolTipService.ToolTip="{x:Bind ViewModel.ComicTitle}" />
                <TextBlock Grid.Column="1"
                           Margin="8,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind ViewModel.ChapterTitle, Mode=OneWay}"
                           TextWrapping="NoWrap"
                           ToolTipService.ToolTip="{x:Bind ViewModel.ChapterTitle, Mode=OneWay}" />
            </Grid>
            <StackPanel Grid.Column="3"
                        Margin="4,0,4,0"
                        Orientation="Horizontal"
                        Spacing="4">
                <Button Command="{x:Bind ViewModel.ForwardChapterNavigationButtonCommand, Mode=OneWay}"
                        Content="{ui:FontIcon Glyph=&#xE76B;}"
                        Style="{StaticResource TitleBarButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.ForwardChapterNavigationButtonToolTip, Mode=OneWay}" />
                <Button Command="{x:Bind ViewModel.BackwardChapterNavigationButtonCommand, Mode=OneWay}"
                        Content="{ui:FontIcon Glyph=&#xE76C;}"
                        Style="{StaticResource TitleBarButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.BackwardChapterNavigationButtonToolTip, Mode=OneWay}" />

                <AppBarSeparator />

                <ToggleButton Width="40"
                              Height="36"
                              Padding="0"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              Command="{x:Bind ViewModel.ToggleFullscreenCommand}"
                              IsChecked="{x:Bind ViewModel.IsFullscreen, Mode=TwoWay}"
                              ToolTipService.ToolTip="Fullscreen">
                    <FontIcon FontSize="16" Glyph="{x:Bind ViewModel.FullscreenButtonIcon, Mode=OneWay}" />
                </ToggleButton>
                <Button Content="{ui:FontIcon Glyph=&#xE712;}" Style="{StaticResource TitleBarButtonStyle}" ToolTipService.ToolTip="Options">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutSubItem x:Uid="ReadingModeSBItem" Icon="{ui:FontIcon Glyph=&#xE736;}">
                                <RadioMenuFlyoutItem x:Uid="RightToLeftModeMNItem"
                                                     Command="{x:Bind ViewModel.SetReadingModeCommand}"
                                                     CommandParameter="RightToLeft"
                                                     GroupName="ReadingMode"
                                                     Icon="{ui:FontIcon Glyph=&#xF0B0;}"
                                                     IsChecked="{x:Bind ViewModel.ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=RightToLeft, Mode=OneWay}" />
                                <RadioMenuFlyoutItem x:Uid="LeftToRightModeMNItem"
                                                     Command="{x:Bind ViewModel.SetReadingModeCommand}"
                                                     CommandParameter="LeftToRight"
                                                     GroupName="ReadingMode"
                                                     Icon="{ui:FontIcon Glyph=&#xF0AF;}"
                                                     IsChecked="{x:Bind ViewModel.ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=LeftToRight, Mode=OneWay}" />
                                <RadioMenuFlyoutItem x:Uid="VerticalModeMNItem"
                                                     Command="{x:Bind ViewModel.SetReadingModeCommand}"
                                                     CommandParameter="Vertical"
                                                     GroupName="ReadingMode"
                                                     Icon="{ui:FontIcon Glyph=&#xF0AE;}"
                                                     IsChecked="{x:Bind ViewModel.ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Vertical, Mode=OneWay}" />
                                <RadioMenuFlyoutItem x:Uid="WebtoonModeMNItem"
                                                     Command="{x:Bind ViewModel.SetReadingModeCommand}"
                                                     CommandParameter="Webtoon"
                                                     GroupName="ReadingMode"
                                                     Icon="{ui:FontIcon Glyph=&#xF0AE;}"
                                                     IsChecked="{x:Bind ViewModel.ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Webtoon, Mode=OneWay}" />
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSubItem x:Uid="ScalingModeSBItem" Icon="{ui:FontIcon Glyph=&#xE9A6;}">
                                <RadioMenuFlyoutItem x:Uid="FitScreenModeMNItem"
                                                     Command="{x:Bind ViewModel.SetScalingModeCommand}"
                                                     CommandParameter="FitScreen"
                                                     GroupName="ScalingMode"
                                                     IsChecked="{x:Bind ViewModel.ScalingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FitScreen, Mode=OneWay}" />
                                <RadioMenuFlyoutItem x:Uid="FitWidthModeMNItem"
                                                     Command="{x:Bind ViewModel.SetScalingModeCommand}"
                                                     CommandParameter="FitWidth"
                                                     GroupName="ScalingMode"
                                                     IsChecked="{x:Bind ViewModel.ScalingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FitWidth, Mode=OneWay}" />
                                <RadioMenuFlyoutItem x:Uid="FitHeightModeMNItem"
                                                     Command="{x:Bind ViewModel.SetScalingModeCommand}"
                                                     CommandParameter="FitHeight"
                                                     GroupName="ScalingMode"
                                                     IsChecked="{x:Bind ViewModel.ScalingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FitHeight, Mode=OneWay}" />
                                <RadioMenuFlyoutItem x:Uid="OriginalSizeModeMNItem"
                                                     Command="{x:Bind ViewModel.SetScalingModeCommand}"
                                                     CommandParameter="OriginalSize"
                                                     GroupName="ScalingMode"
                                                     IsChecked="{x:Bind ViewModel.ScalingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=OriginalSize, Mode=OneWay}" />
                            </MenuFlyoutSubItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <AppBarSeparator Visibility="{x:Bind ViewModel.IsFullscreen, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Loaded="ContentSection_Loaded"
              PointerEntered="ContentSection_PointerEntered"
              PointerExited="ContentSection_PointerExited"
              SizeChanged="ContentSection_SizeChanged">
            <Grid.Transitions>
                <RepositionThemeTransition />
            </Grid.Transitions>
            <FlipView x:Name="PagesFlipView"
                      Background="Transparent"
                      FlowDirection="{x:Bind ViewModel.ReadingMode, Converter={StaticResource ReadingModeToFlowDirectionConverter}, Mode=OneWay}"
                      ItemsSource="{x:Bind ViewModel.ChapterPages, Mode=OneWay}"
                      SelectedIndex="{x:Bind ViewModel.CurrentPageIndex, Mode=TwoWay}"
                      Visibility="{x:Bind ViewModel.IsDefaultReaderVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <FlipView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="{Binding ReadingMode, Converter={StaticResource ReadingModeToOrientationConverter}, Mode=OneWay}" />
                    </ItemsPanelTemplate>
                </FlipView.ItemsPanel>

                <FlipView.Template>
                    <ControlTemplate TargetType="FlipView">
                        <Grid Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="ScrollingHost"
                                          Padding="{TemplateBinding Padding}"
                                          AutomationProperties.AccessibilityView="Raw"
                                          BringIntoViewOnFocusChange="{TemplateBinding ScrollViewer.BringIntoViewOnFocusChange}"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                          HorizontalSnapPointsType="MandatorySingle"
                                          IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                          IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                          IsHorizontalScrollChainingEnabled="{TemplateBinding ScrollViewer.IsHorizontalScrollChainingEnabled}"
                                          IsTabStop="False"
                                          IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                          IsVerticalScrollChainingEnabled="{TemplateBinding ScrollViewer.IsVerticalScrollChainingEnabled}"
                                          TabNavigation="{TemplateBinding TabNavigation}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                          VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                          VerticalSnapPointsType="MandatorySingle"
                                          ZoomMode="Disabled">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Grid>
                    </ControlTemplate>
                </FlipView.Template>

                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="vmc:ChapterPageItemViewModel">
                        <ScrollViewer x:Name="PageScrollViewer"
                                      DoubleTapped="ScrollViewer_DoubleTapped"
                                      FlowDirection="LeftToRight"
                                      HorizontalScrollBarVisibility="Hidden"
                                      HorizontalScrollMode="Auto"
                                      Loaded="ScrollViewer_Loaded"
                                      MinZoomFactor="1"
                                      PointerEntered="ScrollViewer_PointerEntered"
                                      PointerExited="ScrollViewer_PointerExited"
                                      PointerMoved="ScrollViewer_PointerMoved"
                                      PointerPressed="ScrollViewer_PointerPressed"
                                      VerticalScrollBarVisibility="Hidden"
                                      VerticalScrollMode="Auto"
                                      ViewChanged="ScrollViewer_ViewChanged"
                                      ZoomMode="Enabled">

                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressRing Width="45"
                                              Height="45"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsIndeterminate="True"
                                              Visibility="{x:Bind IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="10"
                                            Visibility="{x:Bind HasError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                    <FontIcon HorizontalAlignment="Center"
                                              FontSize="40"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                              Glyph="&#xEB90;" />
                                    <TextBlock x:Uid="FailedLoadingPageTXB" HorizontalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <Button HorizontalAlignment="Center" Command="{x:Bind RetryCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                            <TextBlock x:Uid="TryLoadPageTXB" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Image MaxWidth="{x:Bind PageMaxWidth, Mode=OneWay}"
                                       MaxHeight="{x:Bind PageMaxHeight, Mode=OneWay}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       ImageFailed="Page_ImageFailed"
                                       ImageOpened="Page_ImageOpened"
                                       Source="{x:Bind ImageUrl, Converter={StaticResource UrlToImageConverter}, Mode=OneWay}"
                                       Stretch="Uniform"
                                       Tag="{x:Bind}"
                                       Visibility="{x:Bind HasError, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
                            </Grid>
                        </ScrollViewer>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>

            <Grid>
                <ScrollViewer x:Name="WebtoonScrollViewer"
                              DoubleTapped="ScrollViewer_DoubleTapped"
                              HorizontalScrollBarVisibility="Hidden"
                              HorizontalScrollMode="Auto"
                              Loaded="ScrollViewer_Loaded"
                              MinZoomFactor="1"
                              PointerEntered="ScrollViewer_PointerEntered"
                              PointerExited="ScrollViewer_PointerExited"
                              PointerMoved="ScrollViewer_PointerMoved"
                              PointerPressed="ScrollViewer_PointerPressed"
                              VerticalScrollBarVisibility="Hidden"
                              VerticalScrollMode="Auto"
                              ViewChanged="ScrollViewer_ViewChanged"
                              Visibility="{x:Bind ViewModel.IsWebtoonReaderVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                              ZoomMode="Enabled">
                    <StackPanel>
                        <Border x:Name="TopSpacer" />

                        <ItemsControl x:Name="WebtoonPageItemsControl" ItemsSource="{x:Bind VisibleWebtoonPages, Mode=OneTime}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vmc:ChapterPageItemViewModel">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="{x:Bind WebtoonMaxWidth, Mode=OneWay}"
                                                Height="{x:Bind PlaceholderWebtoonHeight, Mode=OneWay}"
                                                Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                                Visibility="{x:Bind IsWebtoonPlaceholderVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                        <ProgressRing Width="45"
                                                      Height="45"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsIndeterminate="True"
                                                      Visibility="{x:Bind IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="10"
                                                    Visibility="{x:Bind HasError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                            <FontIcon HorizontalAlignment="Center"
                                                      FontSize="40"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                      Glyph="&#xEB90;" />
                                            <TextBlock x:Uid="FailedLoadingPageTXB" HorizontalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Button HorizontalAlignment="Center" Command="{x:Bind RetryCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                                    <TextBlock x:Uid="TryLoadPageTXB" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                        <Image MaxWidth="{x:Bind WebtoonMaxWidth, Mode=OneWay}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               ImageFailed="Page_ImageFailed"
                                               ImageOpened="Page_ImageOpened"
                                               Source="{x:Bind ImageUrl, Converter={StaticResource UrlToImageConverter}, Mode=OneWay}"
                                               Stretch="Uniform"
                                               Tag="{x:Bind}"
                                               Visibility="{x:Bind HasError, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="BottomSpacer" />
                    </StackPanel>
                </ScrollViewer>

                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{x:Bind ViewModel.IsPositioningWebtoonScroll, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <SystemBackdropElement>
                        <SystemBackdropElement.SystemBackdrop>
                            <MicaBackdrop Kind="Base" />
                        </SystemBackdropElement.SystemBackdrop>
                    </SystemBackdropElement>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <ProgressRing Width="45"
                                      Height="45"
                                      HorizontalAlignment="Center"
                                      IsActive="{x:Bind ViewModel.IsPositioningWebtoonScroll, Mode=OneWay}"
                                      IsIndeterminate="True" />
                        <TextBlock x:Uid="LoadingPagesTXB" HorizontalAlignment="Center" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Button x:Name="LeftEdgeButton"
                    Grid.Row="1"
                    Width="48"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ForwardPageNavigationButtonCommand, Mode=OneWay}"
                    Style="{StaticResource PageNavigationButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsHorizontalPageNavigationButtonsVisible, Mode=OneWay}">
                <controls:ShadowedIcon FontSize="20" Glyph="&#xE96F;" OutlineBrush="{ThemeResource FocusStrokeColorInnerBrush}" />
            </Button>
            <Button x:Name="RightEdgeButton"
                    Grid.Row="1"
                    Width="48"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.BackwardPageNavigationButtonCommand, Mode=OneWay}"
                    Style="{StaticResource PageNavigationButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsHorizontalPageNavigationButtonsVisible, Mode=OneWay}">
                <controls:ShadowedIcon FontSize="20" Glyph="&#xE970;" OutlineBrush="{ThemeResource FocusStrokeColorInnerBrush}" />
            </Button>
            <Button x:Name="TopEdgeButton"
                    Grid.Row="1"
                    Height="48"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Command="{x:Bind ViewModel.ForwardPageNavigationButtonCommand, Mode=OneWay}"
                    Style="{StaticResource PageNavigationButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsVerticalPageNavigationButtonsVisible, Mode=OneWay}">
                <controls:ShadowedIcon FontSize="20" Glyph="&#xE96D;" OutlineBrush="{ThemeResource FocusStrokeColorInnerBrush}" />
            </Button>
            <Button x:Name="BottomEdgeButton"
                    Grid.Row="1"
                    Height="48"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.BackwardPageNavigationButtonCommand, Mode=OneWay}"
                    Style="{StaticResource PageNavigationButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsVerticalPageNavigationButtonsVisible, Mode=OneWay}">
                <controls:ShadowedIcon FontSize="20" Glyph="&#xE96E;" OutlineBrush="{ThemeResource FocusStrokeColorInnerBrush}" />
            </Button>

            <controls:ShadowedText x:Name="HorizontalPageIndicator"
                                   Grid.Row="1"
                                   Margin="0,0,0,8"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   OutlineBrush="{ThemeResource FocusStrokeColorInnerBrush}"
                                   Tapped="PageIndicator_Tapped"
                                   Text="{x:Bind ViewModel.PageIndicatorText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.IsHorizontalPageNavigationButtonsVisible, Mode=OneWay}" />
            <controls:ShadowedText x:Name="VerticalPageIndicator"
                                   Grid.Row="1"
                                   Margin="0,8,8,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   OutlineBrush="{ThemeResource FocusStrokeColorInnerBrush}"
                                   Tapped="PageIndicator_Tapped"
                                   Text="{x:Bind ViewModel.PageIndicatorText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.IsVerticalPageNumberIndicatorVisible, Mode=OneWay}" />
        </Grid>

        <Grid Grid.Row="1"
              VerticalAlignment="Center"
              RowDefinitions="Auto, Auto"
              RowSpacing="8"
              Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <ProgressRing Width="64"
                          Height="64"
                          HorizontalAlignment="Center"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          IsIndeterminate="True" />
            <TextBlock x:Uid="LoadingChapterTXB"
                       Grid.Row="1"
                       HorizontalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>


        <Grid Grid.Row="1"
              Margin="16"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RowDefinitions="Auto, Auto, Auto, *, Auto"
              RowSpacing="8"
              Visibility="{x:Bind ViewModel.IsError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <FontIcon FontSize="64"
                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                      Glyph="&#xEB90;"
                      Visibility="{x:Bind ViewModel.IsWarning, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
            <FontIcon FontSize="64"
                      Foreground="{ThemeResource SystemFillColorCautionBrush}"
                      Glyph="&#xF167;"
                      Visibility="{x:Bind ViewModel.IsWarning, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
            <TextBlock Grid.Row="1"
                       HorizontalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="{x:Bind ViewModel.ChapterErrorTitle, Mode=OneWay}" />
            <ScrollViewer Grid.Row="2"
                          MaxWidth="820"
                          MaxHeight="280"
                          Padding="16"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock FontFamily="Consolas"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextSelectionEnabled="True"
                           Text="{x:Bind ViewModel.ChapterErrorMessage, Mode=OneWay}"
                           TextWrapping="Wrap" />
            </ScrollViewer>
            <TextBlock x:Uid="ChapterErrorSuggestionTXB"
                       Grid.Row="3"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Grid>
    </Grid>
</Page>
