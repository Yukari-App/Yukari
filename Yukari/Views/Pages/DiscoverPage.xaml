<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Yukari.Views.Pages.DiscoverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Yukari.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Yukari.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="using:Yukari.Models"
      xmlns:selectors="using:Yukari.Helpers.UI.Selectors"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:vmc="using:Yukari.ViewModels.Components"
      NavigationCacheMode="Enabled"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:UrlToImageConverter x:Key="UrlToImageConverter" />

        <DataTemplate x:Key="ComicTemplate" x:DataType="vmc:ComicItemViewModel">
            <Grid Width="200" Height="280" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">
                <Image Source="{x:Bind Comic.CoverImageUrl, Converter={StaticResource UrlToImageConverter}, Mode=OneTime}" Stretch="UniformToFill" />

                <Grid Height="30"
                      Margin="2"
                      Padding="8,0,4,0"
                      VerticalAlignment="Bottom"
                      Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                      ColumnSpacing="4"
                      CornerRadius="4">
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Comic.Title, Mode=OneTime}" ToolTipService.ToolTip="{x:Bind Comic.Title, Mode=OneTime}" />
                </Grid>

            </Grid>
        </DataTemplate>
    </Page.Resources>


    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Padding="20,14,36,16" ColumnDefinitions="Auto, *, Auto">
            <StackPanel Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <FontIcon FontSize="24" Glyph="&#xE8F1;" />
                <TextBlock Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Text="Discover" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="2">

                <Border Height="20"
                        VerticalAlignment="Center"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.IsSourceOutdated, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Margin="4,0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="Outdated" />
                </Border>

                <ComboBox Height="34"
                          IsEnabled="{x:Bind ViewModel.NoSources, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.ComicSources, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedComicSource, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ComicSourceModel">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="22"
                                       Height="22"
                                       VerticalAlignment="Center"
                                       Source="{x:Bind LogoUrl, Converter={StaticResource UrlToImageConverter}}" />
                                <TextBlock VerticalAlignment="Center" Text="{x:Bind Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Width="34"
                        Height="34"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{x:Bind ViewModel.FilterCommand}"
                        Content="{ui:FontIcon Glyph=&#xE71C;}" />

            </StackPanel>
        </Grid>

        <ProgressRing Grid.Row="1"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsActive="{x:Bind ViewModel.IsContentLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsContentLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Center"
                   Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                   Text="No results found."
                   Visibility="{x:Bind ViewModel.NoResults, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Center"
                   Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                   TextAlignment="Center"
                   Visibility="{x:Bind ViewModel.NoSources, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            It looks like you don't have any Comic Sources. Add one at<LineBreak />
            Settings > Sources > Comic Sources > Add New Source</TextBlock>

        <GridView Grid.Row="1"
                  IsItemClickEnabled="True"
                  ItemClick="GridView_ItemClick"
                  ItemTemplate="{StaticResource ComicTemplate}"
                  ItemsSource="{x:Bind ViewModel.SearchedComics, Mode=OneWay}"
                  SelectionMode="None">
            <GridView.Footer>
                <Button Grid.Row="2"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.LoadMoreCommand}"
                        Visibility="{x:Bind ViewModel.IsLoadMoreVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon FontSize="16" Glyph="&#xE70D;" Visibility="{x:Bind ViewModel.IsLoadingMore, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
                        <ProgressRing Width="16"
                                      Height="16"
                                      IsIndeterminate="True"
                                      Visibility="{x:Bind ViewModel.IsLoadingMore, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        <TextBlock VerticalAlignment="Center" Text="Load More" />
                    </StackPanel>
                </Button>
            </GridView.Footer>
        </GridView>
    </Grid>
</Page>
