<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Yukari.Views.Pages.ComicPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Yukari.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Yukari.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:system="using:System"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:vmc="using:Yukari.ViewModels.Components"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:UrlToImageConverter x:Key="UrlToImageConverter" />

        <DataTemplate x:Key="TagsTemplate" x:DataType="system:String">
            <ItemContainer Height="18"
                           Background="{StaticResource AccentFillColorDefaultBrush}"
                           CornerRadius="8"
                           ToolTipService.ToolTip="{x:Bind}">
                <TextBlock Margin="5,0,5,0"
                           FontSize="12"
                           Foreground="{StaticResource TextOnAccentFillColorPrimaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Text="{x:Bind}" />
            </ItemContainer>
        </DataTemplate>

        <DataTemplate x:Key="GroupsTemplate" x:DataType="system:String">
            <ItemContainer Margin="0" CornerRadius="8" ToolTipService.ToolTip="{x:Bind}">
                <Grid Height="16"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      CornerRadius="8">
                    <TextBlock MaxWidth="140"
                               Margin="4,0,4,0"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="{x:Bind}" />
                </Grid>
            </ItemContainer>
        </DataTemplate>

        <DataTemplate x:Key="ChaptersTemplate" x:DataType="vmc:ChapterItemViewModel">
            <Button Padding="6"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Command="{x:Bind NavigateToReaderCommand}"
                    CommandParameter="{x:Bind Key}"
                    CornerRadius="4"
                    IsEnabled="{x:Bind IsChapterAvailable, Mode=OneWay}">
                <Button.Resources>
                    <Color x:Key="ButtonBorderBrushDisabled">Transparent</Color>
                </Button.Resources>
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Grid Grid.Column="0" HorizontalAlignment="Stretch" RowDefinitions="Auto, 20, *">
                        <TextBlock Grid.Row="0"
                                   FontSize="18"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Text="{x:Bind DisplayTitle}" />

                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal"
                                    Spacing="4">
                            <ItemsView ItemTemplate="{StaticResource GroupsTemplate}" ItemsSource="{x:Bind DisplayGroups, Mode=OneWay}" SelectionMode="None">
                                <ItemsView.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="5" />
                                </ItemsView.Layout>
                            </ItemsView>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ExtraGroupsText, Mode=OneWay}"
                                       Visibility="{x:Bind HasMoreGroups, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Bottom"
                                   FontSize="14"
                                   Text="{x:Bind Chapter.LastUpdate}" />
                    </Grid>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Orientation="Horizontal"
                                Spacing="4">
                        <StackPanel.Resources>
                            <Color x:Key="ButtonBackgroundDisabled">Transparent</Color>
                            <Color x:Key="ToggleButtonBackgroundDisabled">Transparent</Color>
                            <Color x:Key="ToggleButtonBorderBrushDisabled">Transparent</Color>
                        </StackPanel.Resources>
                        <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="4">
                            <Border Height="20"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind IsDownloadQueued, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <TextBlock Margin="4,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Text="Queued" />
                            </Border>
                            <Border Height="20"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind IsDownloadCancelled, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <TextBlock Margin="4,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Text="Cancelled" />
                            </Border>
                            <Border Height="20"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{x:Bind IsDownloadFailed, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <TextBlock Margin="4,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Text="Failed" />
                            </Border>

                            <ProgressRing Grid.Column="1"
                                          Width="28"
                                          Height="28"
                                          Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                          IsIndeterminate="False"
                                          Maximum="1"
                                          Visibility="{x:Bind IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                          Value="{x:Bind DownloadProgress, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       Text="{x:Bind FormattedDownloadProgress, Mode=OneWay}"
                                       Visibility="{x:Bind IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        </Grid>
                        <ToggleButton Width="32"
                                      Height="32"
                                      Padding="0"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      Command="{x:Bind ToggleDownloadCommand}"
                                      IsChecked="{x:Bind DownloadButtonValue, Mode=OneWay}"
                                      Visibility="{x:Bind IsDownloadAvailable, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <FontIcon Glyph="{x:Bind DownloadIcon, Mode=OneWay}" />
                        </ToggleButton>
                        <ToggleButton Width="32"
                                      Height="32"
                                      Padding="0"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      Command="{x:Bind ToggleReadCommand}"
                                      IsChecked="{x:Bind IsRead, Mode=TwoWay}">
                            <FontIcon Glyph="{x:Bind ReadIcon, Mode=OneWay}" />
                        </ToggleButton>
                        <Button Width="32"
                                Height="32"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Content="{ui:FontIcon Glyph=&#xE712;}">
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Command="{x:Bind MarkPreviousChaptersAsReadCommand}"
                                                    CommandParameter="{x:Bind}"
                                                    Icon="{ui:FontIcon Glyph=&#xE890;}"
                                                    Text="Mark previous chapters as read" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Text="{x:Bind PageProgressText, Mode=OneWay}" />
                </Grid>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid RowDefinitions="Auto, *" Visibility="{x:Bind ViewModel.IsComicLoaded, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <Grid Grid.Row="0"
                  MaxWidth="1000"
                  Padding="20,14,36,16"
                  ColumnDefinitions="*, Auto, Auto"
                  ColumnSpacing="8">
                <Grid Grid.Column="0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      ColumnDefinitions="Auto, *"
                      ColumnSpacing="8">
                    <FontIcon Grid.Column="0" FontSize="24" Glyph="&#xE82D;" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Style="{StaticResource TitleTextBlockStyle}"
                               Text="{x:Bind ViewModel.Comic.Title, Mode=OneWay}"
                               TextWrapping="NoWrap"
                               ToolTipService.ToolTip="{x:Bind ViewModel.Comic.Title, Mode=OneWay}" />
                </Grid>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Text="{x:Bind ViewModel.Comic.Source, Mode=OneWay}" />

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                    <Button Command="{x:Bind ViewModel.ContinueReadingCommand}" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xF5B0;" />
                            <TextBlock Text="Continue" />
                        </StackPanel>
                    </Button>

                    <ToggleButton Width="32"
                                  Height="32"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  Command="{x:Bind ViewModel.ToggleFavoriteCommand}"
                                  IsChecked="{x:Bind ViewModel.IsFavorite, Mode=TwoWay}">
                        <FontIcon Glyph="{x:Bind ViewModel.FavoriteIcon, Mode=OneWay}" />
                    </ToggleButton>

                    <Button Width="32"
                            Height="32"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Content="{ui:FontIcon Glyph=&#xE712;}">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem Command="{x:Bind ViewModel.UpdateCommand}"
                                                Icon="Refresh"
                                                IsEnabled="{x:Bind ViewModel.IsFavoriteStatusChanging, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"
                                                Text="Update"
                                                Visibility="{x:Bind ViewModel.IsOnlineFeaturesVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.IsOnlineFeaturesVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                <MenuFlyoutItem Command="{x:Bind ViewModel.OpenLocalComicManagerCommand}"
                                                Icon="Edit"
                                                IsEnabled="{x:Bind ViewModel.IsFavoriteStatusChanging, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"
                                                Text="Edit Local Comic"
                                                Visibility="{x:Bind ViewModel.IsLocalComic, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                <MenuFlyoutItem Command="{x:Bind ViewModel.OpenComicCollectionsManagerCommand}"
                                                IsEnabled="{x:Bind ViewModel.IsFavoriteStatusChanging, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"
                                                Text="Collections"
                                                Visibility="{x:Bind ViewModel.IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                    <MenuFlyoutItem.Icon>
                                        <PathIcon VerticalAlignment="Center" Data="M4.6543 2C4.94884 1.40731 5.56045 1 6.26719 1H10.9004C12.6125 1 14.0004 2.38792 14.0004 4.1V11.4667C14.0004 12.1734 13.5931 12.785 13.0004 13.0796V4.1C13.0004 2.9402 12.0602 2 10.9004 2H4.6543ZM4.8 3C3.80589 3 3 3.80589 3 4.8V14.4991C3 14.6724 3.08971 14.8333 3.2371 14.9244C3.38448 15.0155 3.56853 15.0238 3.72353 14.9463L7.5 13.059L11.2765 14.9463C11.4315 15.0238 11.6155 15.0155 11.7629 14.9244C11.9103 14.8333 12 14.6724 12 14.4991V4.8C12 3.80589 11.1941 3 10.2 3H4.8ZM4 4.8C4 4.35817 4.35817 4 4.8 4H10.2C10.6418 4 11 4.35817 11 4.8V13.6902L7.72353 12.0527C7.58281 11.9824 7.41719 11.9824 7.27647 12.0527L4 13.6902V4.8Z" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.IsOnlineFeaturesVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                <MenuFlyoutItem Command="{x:Bind ViewModel.OpenInBrowserCommand}"
                                                Icon="Globe"
                                                Text="Open in browser"
                                                Visibility="{x:Bind ViewModel.IsLocalComic, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>


            <ScrollViewer Grid.Row="1">
                <Grid Padding="0,0,16,16">
                    <Grid MaxWidth="1000" RowDefinitions="Auto, Auto">
                        <InfoBar Title="This comic is no longer available in its source."
                                 Grid.Row="0"
                                 Margin="0,0,0,16"
                                 IsClosable="False"
                                 IsOpen="True"
                                 Message="You can still read downloaded chapters."
                                 Severity="Warning"
                                 Visibility="{x:Bind ViewModel.IsComicAvailable, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />

                        <Grid Grid.Row="1" RowDefinitions="280, Auto, Auto" RowSpacing="16">
                            <Grid Grid.Row="0"
                                  HorizontalAlignment="Stretch"
                                  ColumnDefinitions="Auto, *"
                                  ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        MaxWidth="200"
                                        MaxHeight="280"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        CornerRadius="8">
                                    <Image Source="{Binding Comic.CoverImageUrl, Converter={StaticResource UrlToImageConverter}, Mode=OneWay}" Stretch="Fill" />
                                </Border>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon VerticalAlignment="Center" FontSize="20" Glyph="&#xE716;" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="20"
                                                   Style="{StaticResource TitleTextBlockStyle}"
                                                   Text="Author(s)" />
                                    </StackPanel>
                                    <TextBlock Margin="0,0,0,12" FontSize="16" Text="{x:Bind ViewModel.AuthorDisplay, Mode=OneWay}" />

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon VerticalAlignment="Center" FontSize="20" Glyph="&#xE787;" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="20"
                                                   Style="{StaticResource TitleTextBlockStyle}"
                                                   Text="Published" />
                                    </StackPanel>
                                    <TextBlock Margin="0,0,0,12" FontSize="16" Text="{x:Bind ViewModel.Comic.Year, Mode=OneWay}" />

                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.IsLocalComic, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}">
                                        <FontIcon VerticalAlignment="Center" FontSize="20" Glyph="&#xE9D9;" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="20"
                                                   Style="{StaticResource TitleTextBlockStyle}"
                                                   Text="Status" />
                                    </StackPanel>
                                    <TextBlock Margin="0,0,0,12"
                                               FontSize="16"
                                               Text="{x:Bind ViewModel.StatusDisplay, Mode=OneWay}"
                                               Visibility="{x:Bind ViewModel.IsLocalComic, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />

                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.IsTagsVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                        <FontIcon VerticalAlignment="Center" FontSize="20" Glyph="&#xE8EC;" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="20"
                                                   Style="{StaticResource TitleTextBlockStyle}"
                                                   Text="Tags" />
                                        <TextBlock VerticalAlignment="Bottom"
                                                   FontSize="14"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Text="{x:Bind ViewModel.HiddenTagsText, Mode=OneWay}"
                                                   Visibility="{x:Bind ViewModel.HasHiddenTags, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                    </StackPanel>
                                    <ItemsView Margin="0,8,0,0"
                                               ItemTemplate="{StaticResource TagsTemplate}"
                                               ItemsSource="{x:Bind ViewModel.DisplayTags, Mode=OneWay}"
                                               SelectionMode="None">
                                        <ItemsView.Layout>
                                            <LinedFlowLayout LineSpacing="4.2" MinItemSpacing="5" />
                                        </ItemsView.Layout>
                                    </ItemsView>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon VerticalAlignment="Center" FontSize="20" Glyph="&#xE946;" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="20"
                                               Style="{StaticResource TitleTextBlockStyle}"
                                               Text="Synopsis" />
                                </StackPanel>
                                <ScrollViewer MaxHeight="120"
                                              Padding="6,0,16,0"
                                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                              BorderThickness="1"
                                              CornerRadius="8">
                                    <TextBlock Margin="0,0,0,2"
                                               FontSize="16"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               Text="{x:Bind ViewModel.Comic.Description, Mode=OneWay, TargetNullValue='No description available.'}"
                                               TextAlignment="Justify"
                                               TextWrapping="WrapWholeWords" />
                                </ScrollViewer>
                            </StackPanel>

                            <Grid Grid.Row="2" RowDefinitions="Auto, *" RowSpacing="12">
                                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon VerticalAlignment="Center" FontSize="24" Glyph="&#xE736;" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="24"
                                                   Style="{StaticResource TitleTextBlockStyle}"
                                                   Text="Chapters" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Command="{x:Bind ViewModel.RescanChaptersCommand}" Visibility="{x:Bind ViewModel.IsLocalComic, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                                <TextBlock Text="Rescan Chapters" />
                                            </StackPanel>
                                        </Button>

                                        <ToggleButton Command="{x:Bind ViewModel.ToggleDownloadAllChaptersCommand}" IsChecked="{x:Bind ViewModel.IsAllChaptersDownloaded, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsOnlineFeaturesVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="16" Glyph="{x:Bind ViewModel.DownloadAllIcon, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind ViewModel.DownloadAllText, Mode=OneWay}" />
                                            </StackPanel>
                                        </ToggleButton>

                                        <ComboBox DisplayMemberPath="DisplayName"
                                                  IsEnabled="{x:Bind ViewModel.IsLanguageSelectionAvailable, Mode=OneWay}"
                                                  ItemsSource="{x:Bind ViewModel.Comic.Langs, Mode=OneWay}"
                                                  SelectedValue="{x:Bind ViewModel.SelectedLang, Mode=TwoWay}"
                                                  SelectedValuePath="Key" />

                                        <Button Width="32"
                                                Height="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Content="{ui:FontIcon Glyph=&#xE712;}"
                                                IsEnabled="{x:Bind ViewModel.IsInterfaceReady, Mode=OneWay}">
                                            <Button.Flyout>
                                                <MenuFlyout Placement="Bottom">
                                                    <MenuFlyoutItem Command="{x:Bind ViewModel.MarkAllAsReadCommand}" Icon="{ui:FontIcon Glyph=&#xE890;}" Text="Mark all as read" />
                                                    <MenuFlyoutItem Command="{x:Bind ViewModel.MarkAllAsUnreadCommand}" Icon="{ui:FontIcon Glyph=&#xED1A;}" Text="Mark all as unread" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>

                                </Grid>

                                <ProgressRing Grid.Row="1"
                                              Width="40"
                                              Height="40"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsActive="{x:Bind ViewModel.IsChaptersLoading, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.IsChaptersLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                <TextBlock Grid.Row="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                                           Text="No chapters found in this language."
                                           Visibility="{x:Bind ViewModel.NoChapters, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                <ItemsRepeater Grid.Row="1"
                                               IsTapEnabled="False"
                                               ItemTemplate="{StaticResource ChaptersTemplate}"
                                               ItemsSource="{x:Bind ViewModel.Chapters, Mode=OneWay}"
                                               Visibility="{x:Bind ViewModel.IsChaptersLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Grid Padding="0,0,16,16"
              VerticalAlignment="Center"
              RowDefinitions="Auto, Auto"
              RowSpacing="8"
              Visibility="{x:Bind ViewModel.IsComicLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <ProgressRing Width="64"
                          Height="64"
                          HorizontalAlignment="Center"
                          IsActive="{x:Bind ViewModel.IsComicLoading, Mode=OneWay}"
                          IsIndeterminate="True" />
            <TextBlock Grid.Row="1"
                       HorizontalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Loading Comic..." />
        </Grid>

        <Grid MaxWidth="1000"
              Padding="0,0,16,16"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RowDefinitions="Auto, Auto, Auto, *, Auto"
              RowSpacing="8"
              Visibility="{x:Bind ViewModel.IsComicError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <FontIcon FontSize="64" Foreground="{StaticResource SystemFillColorCriticalBrush}" Glyph="&#xEB90;" />
            <TextBlock Grid.Row="1"
                       HorizontalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="{x:Bind ViewModel.ComicErrorTitle, Mode=OneWay}" />
            <ScrollViewer Grid.Row="2"
                          MaxWidth="820"
                          MaxHeight="280"
                          Padding="16"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock FontFamily="Consolas"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextSelectionEnabled="True"
                           Text="{x:Bind ViewModel.ComicErrorMessage, Mode=OneWay}"
                           TextWrapping="Wrap" />
            </ScrollViewer>
            <TextBlock Grid.Row="3"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="Try going back and selecting the comic again."
                       TextAlignment="Center" />

        </Grid>
    </Grid>
</Page>
