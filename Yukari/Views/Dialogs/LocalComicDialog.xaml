<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="Yukari.Views.Dialogs.LocalComicDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:converters="using:Yukari.Helpers.UI.Converters"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:enums="using:Yukari.Enums"
               xmlns:helpers="using:Yukari.Helpers.UI"
               xmlns:local="using:Yukari.Views.Dialogs"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:ui="using:CommunityToolkit.WinUI"
               x:Uid="LocalComicManagerDialog"
               DefaultButton="Primary"
               IsPrimaryButtonEnabled="{x:Bind ViewModel.IsPrimaryButtonEnabled, Mode=OneWay}"
               PrimaryButtonCommand="{x:Bind ViewModel.SaveLocalComicCommand}"
               PrimaryButtonText="{x:Bind ViewModel.PrimaryButtonText, Mode=OneWay}"
               Style="{StaticResource DefaultContentDialogStyle}"
               mc:Ignorable="d">
    <ContentDialog.Title>
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="24" Glyph="&#xE8B7;" />
            <TextBlock x:Uid="LocalComicManagerHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
        </StackPanel>
    </ContentDialog.Title>

    <ContentDialog.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="480">
        <Grid Width="320">
            <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsError, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}">
                <TextBox x:Uid="TitleTXBox" Text="{x:Bind ViewModel.Title, Mode=TwoWay}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                    <TextBox x:Uid="AuthorTXBox" Grid.Column="0" Text="{x:Bind ViewModel.Author, Mode=TwoWay}" />
                    <NumberBox x:Uid="YearNBox"
                               Grid.Column="1"
                               Maximum="9999"
                               Minimum="1"
                               SpinButtonPlacementMode="Compact"
                               Value="{x:Bind ViewModel.Year, Mode=TwoWay}" />
                </Grid>

                <TextBox x:Uid="TagsTXBox" Text="{x:Bind ViewModel.Tags, Mode=TwoWay}" />
                <TextBox x:Uid="DescriptionTXBox"
                         MaxHeight="100"
                         Text="{x:Bind ViewModel.Description, Mode=TwoWay}"
                         TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="2">
                    <TextBox x:Uid="CoverTXBox" Grid.Column="0" Text="{x:Bind ViewModel.CoverPath, Mode=TwoWay}" />
                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            VerticalAlignment="Bottom"
                            Command="{x:Bind ViewModel.OpenCoverPickerCommand}"
                            Content="{ui:FontIcon Glyph=&#xE7C5;}" />
                </Grid>

                <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="2">
                    <TextBox x:Uid="ComicFolderTXBox" Grid.Column="0" Text="{x:Bind ViewModel.ComicFolderPath, Mode=TwoWay}" />
                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="0"
                            VerticalAlignment="Bottom"
                            Command="{x:Bind ViewModel.OpenComicPathPickerCommand}"
                            Content="{ui:FontIcon Glyph=&#xF89A;}" />
                    <ComboBox x:Uid="ChapterFormatCBBox"
                              Grid.Column="2"
                              Width="108"
                              Margin="2,0,0,0"
                              ItemsSource="{x:Bind ViewModel.AvailableChaptersFormat}"
                              SelectedItem="{x:Bind ViewModel.SelectedChaptersFormat, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="enums:LocalChaptersFormat">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon VerticalAlignment="Center" FontSize="14" Glyph="{x:Bind helpers:LocalChaptersFormatHelper.ToGlyph((enums:LocalChaptersFormat))}" />
                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind helpers:LocalChaptersFormatHelper.ToDisplayName((enums:LocalChaptersFormat))}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  RowDefinitions="Auto, Auto, Auto"
                  RowSpacing="8"
                  Visibility="{x:Bind ViewModel.IsError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <FontIcon FontSize="48" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xEB90;" />
                <TextBlock x:Uid="LocalComicManagerErrorTXB"
                           Grid.Row="1"
                           HorizontalAlignment="Center"
                           Style="{StaticResource BodyLargeStrongTextBlockStyle}" />
                <ScrollViewer Grid.Row="2"
                              MaxWidth="320"
                              MaxHeight="200"
                              Padding="8"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              CornerRadius="8"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock FontFamily="Consolas"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               IsTextSelectionEnabled="True"
                               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </ScrollViewer>

            </Grid>
        </Grid>
    </ScrollViewer>
</ContentDialog>