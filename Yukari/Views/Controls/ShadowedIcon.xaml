<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Yukari.Views.Controls.ShadowedIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid x:Name="RootGrid">
        <FontIcon Margin="1,0,0,0"
                  FontSize="{x:Bind FontSize, Mode=OneWay}"
                  Foreground="{x:Bind OutlineBrush, Mode=OneWay}"
                  Glyph="{x:Bind Glyph, Mode=OneWay}" />
        <FontIcon Margin="-1,0,0,0"
                  FontSize="{x:Bind FontSize, Mode=OneWay}"
                  Foreground="{x:Bind OutlineBrush, Mode=OneWay}"
                  Glyph="{x:Bind Glyph, Mode=OneWay}" />
        <FontIcon Margin="0,1,0,0"
                  FontSize="{x:Bind FontSize, Mode=OneWay}"
                  Foreground="{x:Bind OutlineBrush, Mode=OneWay}"
                  Glyph="{x:Bind Glyph, Mode=OneWay}" />
        <FontIcon Margin="0,-1,0,0"
                  FontSize="{x:Bind FontSize, Mode=OneWay}"
                  Foreground="{x:Bind OutlineBrush, Mode=OneWay}"
                  Glyph="{x:Bind Glyph, Mode=OneWay}" />
        <FontIcon FontSize="{x:Bind FontSize, Mode=OneWay}" Foreground="{x:Bind Foreground, Mode=OneWay}" Glyph="{x:Bind Glyph, Mode=OneWay}" />
    </Grid>
</UserControl>